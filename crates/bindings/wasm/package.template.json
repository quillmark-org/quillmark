{
  "name": "@quillmark/wasm",
  "version": "VERSION_PLACEHOLDER",
  "description": "WebAssembly bindings for quillmark",
  "type": "module",
  "license": "MIT OR Apache-2.0",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quillmark-org/quillmark.git"
  },
  "files": [
    "core",
    "render",
    "CHANGELOG.md"
  ],
  "main": "./render/wasm.js",
  "module": "./render/wasm.js",
  "types": "./render/wasm.d.ts",
  "exports": {
    ".": {
      "types": "./render/wasm.d.ts",
      "import": "./render/wasm.js",
      "default": "./render/wasm.js"
    },
    "./core": {
      "types": "./core/wasm.d.ts",
      "import": "./core/wasm.js",
      "default": "./core/wasm.js"
    }
  },
  "sideEffects": [
    "./core/wasm.js",
    "./render/wasm.js"
  ]
}
