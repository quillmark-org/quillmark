{
  "name": "@quillmark/wasm",
  "version": "VERSION_PLACEHOLDER",
  "description": "WebAssembly bindings for Quillmark, a schema-driven document engine",
  "type": "module",
  "license": "MIT OR Apache-2.0",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quillmark-org/quillmark.git"
  },
  "files": [
    "core",
    "backends",
    "runtime",
    "CHANGELOG.md"
  ],
  "main": "./runtime/runtime.js",
  "module": "./runtime/runtime.js",
  "types": "./runtime/runtime.d.ts",
  "exports": {
    ".": {
      "types": "./runtime/runtime.d.ts",
      "import": "./runtime/runtime.js",
      "default": "./runtime/runtime.js"
    }
  },
  "sideEffects": [
    "./core/wasm.js",
    "./backends/typst/wasm.js",
    "./backends/pdfform/wasm.js",
    "./runtime/runtime.js"
  ]
}
